{
  "firestore": {
    "database": "(default)",
    "location": "asia-southeast1",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "auth": {
    "providers": {
      "googleSignIn": {
        "oAuthBrandDisplayName": "Aqina Admin",
        "supportEmail": "ohweiyang333@gmail.com"
      }
    }
  },
  "hosting": [
    {
      "target": "aqina-v2",
      "public": "frontend/public",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "**",
          "run": {
            "serviceId": "aqina-frontend-v2",
            "region": "asia-southeast1"
          }
        }
      ]
    }
  ]
}
