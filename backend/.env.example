# Firebase
FIREBASE_PROJECT_ID=aqina-chicken-essence
FIREBASE_STORAGE_BUCKET=aqina-chicken-essence.firebasestorage.app

# Runtime
ENVIRONMENT=production
CORS_ORIGINS=["http://localhost:3000","https://aqina-sg.web.app","https://aqina-sg.firebaseapp.com","https://aqina-frontend-c3amale25a-as.a.run.app","https://aqina-frontend-v2-c3amale25a-as.a.run.app"]

# JWT
JWT_SECRET=replace-with-random-session-secret
JWT_ALGORITHM=HS256
JWT_EXPIRATION=86400

# Meta
META_VERIFY_TOKEN=replace-with-webhook-verify-token
META_APP_SECRET=replace-with-meta-app-secret
META_GRAPH_API_VERSION=v22.0
META_PAGE_ACCESS_TOKEN=replace-with-page-access-token
META_PAGE_ID=replace-with-page-id
META_COMMENT_REPLY_TEMPLATE=__TODO__
META_PRIVATE_REPLY_TEMPLATE=__TODO__
META_WHATSAPP_ACCESS_TOKEN=replace-with-whatsapp-access-token
META_WHATSAPP_PHONE_NUMBER_ID=replace-with-phone-number-id
META_WHATSAPP_BUSINESS_ACCOUNT_ID=replace-with-whatsapp-business-account-id

# Gemini
GEMINI_API_KEY=replace-with-gemini-api-key
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_SYSTEM_PROMPT=stored-in-chatbotSettings-default

# CRM follow-up
CRM_FOLLOW_UP_RULES=stored-in-chatbotSettings-default

# Internal task routing
INTERNAL_TASK_SECRET=replace-with-random-shared-secret
BACKEND_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:3000

# Cloud Tasks
CLOUD_TASKS_ENABLED=false
CLOUD_TASKS_PROJECT_ID=aqina-chicken-essence
CLOUD_TASKS_LOCATION=asia-southeast1
CLOUD_TASKS_EVENTS_QUEUE=marketing-events
CLOUD_TASKS_FOLLOWUPS_QUEUE=marketing-followups
CLOUD_TASKS_CAMPAIGNS_QUEUE=whatsapp-campaigns
