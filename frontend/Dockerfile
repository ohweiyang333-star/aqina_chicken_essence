# Build stage
FROM node:20-alpine AS builder

# Accept build arguments for Firebase and public runtime config
ARG NEXT_PUBLIC_API_URL
ARG NEXT_PUBLIC_FIREBASE_API_KEY
ARG NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN
ARG NEXT_PUBLIC_FIREBASE_PROJECT_ID
ARG NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET
ARG NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID
ARG NEXT_PUBLIC_FIREBASE_APP_ID
ARG NEXT_PUBLIC_WHATSAPP_DISPLAY
ARG NEXT_PUBLIC_WHATSAPP_LINK
ARG NEXT_PUBLIC_CONTACT_EMAIL
ARG NEXT_PUBLIC_PAYMENT_QR_IMAGE
ARG NEXT_PUBLIC_PAYMENT_QR_ALT
ARG NEXT_PUBLIC_PAYMENT_ACCOUNT_NAME
ARG NEXT_PUBLIC_WHATSAPP_PREFILL

WORKDIR /app

# Set environment variables from build arguments
ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}
ENV NEXT_PUBLIC_FIREBASE_API_KEY=${NEXT_PUBLIC_FIREBASE_API_KEY}
ENV NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=${NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN}
ENV NEXT_PUBLIC_FIREBASE_PROJECT_ID=${NEXT_PUBLIC_FIREBASE_PROJECT_ID}
ENV NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=${NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET}
ENV NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=${NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID}
ENV NEXT_PUBLIC_FIREBASE_APP_ID=${NEXT_PUBLIC_FIREBASE_APP_ID}
ENV NEXT_PUBLIC_WHATSAPP_DISPLAY=${NEXT_PUBLIC_WHATSAPP_DISPLAY}
ENV NEXT_PUBLIC_WHATSAPP_LINK=${NEXT_PUBLIC_WHATSAPP_LINK}
ENV NEXT_PUBLIC_CONTACT_EMAIL=${NEXT_PUBLIC_CONTACT_EMAIL}
ENV NEXT_PUBLIC_PAYMENT_QR_IMAGE=${NEXT_PUBLIC_PAYMENT_QR_IMAGE}
ENV NEXT_PUBLIC_PAYMENT_QR_ALT=${NEXT_PUBLIC_PAYMENT_QR_ALT}
ENV NEXT_PUBLIC_PAYMENT_ACCOUNT_NAME=${NEXT_PUBLIC_PAYMENT_ACCOUNT_NAME}
ENV NEXT_PUBLIC_WHATSAPP_PREFILL=${NEXT_PUBLIC_WHATSAPP_PREFILL}

# Copy package files
COPY package.json package-lock.json ./

# Install dependencies
RUN npm ci

# Copy source code
COPY . .

# Build the application
RUN NEXT_TELEMETRY_DISABLED=1 npm run build

# Production stage
FROM node:20-alpine AS runner

ARG NEXT_PUBLIC_API_URL
ARG NEXT_PUBLIC_FIREBASE_API_KEY
ARG NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN
ARG NEXT_PUBLIC_FIREBASE_PROJECT_ID
ARG NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET
ARG NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID
ARG NEXT_PUBLIC_FIREBASE_APP_ID
ARG NEXT_PUBLIC_WHATSAPP_DISPLAY
ARG NEXT_PUBLIC_WHATSAPP_LINK
ARG NEXT_PUBLIC_CONTACT_EMAIL
ARG NEXT_PUBLIC_PAYMENT_QR_IMAGE
ARG NEXT_PUBLIC_PAYMENT_QR_ALT
ARG NEXT_PUBLIC_PAYMENT_ACCOUNT_NAME
ARG NEXT_PUBLIC_WHATSAPP_PREFILL

WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}
ENV NEXT_PUBLIC_FIREBASE_API_KEY=${NEXT_PUBLIC_FIREBASE_API_KEY}
ENV NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=${NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN}
ENV NEXT_PUBLIC_FIREBASE_PROJECT_ID=${NEXT_PUBLIC_FIREBASE_PROJECT_ID}
ENV NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=${NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET}
ENV NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=${NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID}
ENV NEXT_PUBLIC_FIREBASE_APP_ID=${NEXT_PUBLIC_FIREBASE_APP_ID}
ENV NEXT_PUBLIC_WHATSAPP_DISPLAY=${NEXT_PUBLIC_WHATSAPP_DISPLAY}
ENV NEXT_PUBLIC_WHATSAPP_LINK=${NEXT_PUBLIC_WHATSAPP_LINK}
ENV NEXT_PUBLIC_CONTACT_EMAIL=${NEXT_PUBLIC_CONTACT_EMAIL}
ENV NEXT_PUBLIC_PAYMENT_QR_IMAGE=${NEXT_PUBLIC_PAYMENT_QR_IMAGE}
ENV NEXT_PUBLIC_PAYMENT_QR_ALT=${NEXT_PUBLIC_PAYMENT_QR_ALT}
ENV NEXT_PUBLIC_PAYMENT_ACCOUNT_NAME=${NEXT_PUBLIC_PAYMENT_ACCOUNT_NAME}
ENV NEXT_PUBLIC_WHATSAPP_PREFILL=${NEXT_PUBLIC_WHATSAPP_PREFILL}

# Create non-root user
RUN addgroup --system --gid 1001 nodejs
RUN adduser --system --uid 1001 nextjs

# Copy necessary files from builder
COPY --from=builder /app/public ./public
COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static

# Set correct permissions
RUN chown -R nextjs:nodejs /app

USER nextjs

EXPOSE 3000

ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

CMD ["node", "server.js"]
